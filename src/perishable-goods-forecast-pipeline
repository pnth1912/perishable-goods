#── 3.Build hierarchies
def build_hierarchy(data_raw):
    region_store_map = (
        data_raw.groupby('region')['store_id']
        .apply(list)
        .apply(lambda x: sorted(set(x)))
        .to_dict()
    )
    regions    = sorted(region_store_map.keys())
    all_stores = sorted(data_raw['store_id'].unique())
    all_series = ['Total'] + regions + all_stores

    # Pivot to wide format (date x series)
    data_wide = data_raw.pivot_table(
        index='transaction_date', columns='store_id',
        values='units_sold', aggfunc='sum'
    ).fillna(0)

    # ── Fix: enforce daily frequency, fill gaps with 0 ───────────────
    data_wide.index = pd.to_datetime(data_wide.index)
    data_wide = data_wide.resample('D').sum().fillna(0)

    # Add region aggregates
    for region, stores in region_store_map.items():
        data_wide[region] = data_wide[stores].sum(axis=1)

    # Add total
    data_wide['Total'] = data_wide[all_stores].sum(axis=1)

    # Reorder columns
    data_wide = data_wide[all_series]

    # Build S matrix
    n_series  = len(all_series)
    n_stores  = len(all_stores)
    S         = np.zeros((n_series, n_stores), dtype=float)
    store_idx = {s: i for i, s in enumerate(all_stores)}

    for row_idx, series in enumerate(all_series):
        if series == 'Total':
            S[row_idx, :] = 1
        elif series in region_store_map:
            for s in region_store_map[series]:
                S[row_idx, store_idx[s]] = 1
        elif series in store_idx:
            S[row_idx, store_idx[series]] = 1

    return data_wide, S, all_series, all_stores, region_store_map

